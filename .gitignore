# ============================================================
# Auto E-learning workspace .gitignore
# Large binaries, caches, environment-specific files
# ============================================================

# Node / Hyperframes
**/node_modules/
**/.next/
**/dist/
**/build/
**/.hyperframes-cache/
package-lock.json
**/snapshots/

# macOS / Editor
.DS_Store
**/.DS_Store
.vscode/
.idea/
*.swp

# Python
**/__pycache__/
**/*.pyc
.venv/
venv/

# Logs / temp
*.log
npm-debug.log*
.npm/
/tmp/

# ===== Large media binaries (재생성 가능) =====
# 원본 녹음 (재녹음 가능)
**/04_녹음/원본/*.mp4
**/04_녹음/원본/*.mp3
**/04_녹음/원본/*.mov
**/04_녹음/원본/*.m4a
**/04_녹음/원본/*.wav

# 가공된 wav (ffmpeg로 재생성 가능)
**/04_녹음/가공/*.wav

# Hyperframes assets/audio (재생성 가능)
**/06_편집/hyperframes/assets/audio/*.wav

# 프리뷰·렌더 결과물 (재렌더 가능)
**/06_편집/프리뷰/*.mp4
**/06_편집/프리뷰/*.mov
**/07_최종/마스터/*.mp4
**/07_최종/마스터/*.mov
**/07_최종/납품/*.mp4
**/07_최종/납품/*.mov

# 백업 파일
**/*.bak

# Whisper 모델 캐시 (수GB, 자동 다운로드 가능)
.cache/whisper-models/

# ===== .gitkeep 은 유지 =====
!.gitkeep
